# Copy to keystore.properties (gitignored) and fill in.
# Generate the keystore once with:
#   keytool -genkey -v -keystore upload.keystore -alias upload \
#     -keyalg RSA -keysize 2048 -validity 10000
# Keep upload.keystore out of git and back it up somewhere safe.
storeFile=../upload.keystore
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
